# Bellory local development environment.
# Copy this file to .env.local and fill in real values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
ENCRYPTION_KEY=replace-with-32-byte-base64-key
AGENT_TOOL_SHARED_SECRET=replace-with-random-shared-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth - Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_PROJECT_ID=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
